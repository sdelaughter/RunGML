        ["if", ["control_check", ["v", "controls"], "reset"], {"True": ["pass",
            ["v", "score_l", 0],
            ["v", "score_r", 0],
            ["run", ["s", ["v", "hf"], "reset"]]
        ]}],
        ["if", ["control_check", ["v", "controls"], "singleplayer"], {"True":
            ["v", "singleplayer", ["sub", 1, ["v", "singleplayer"]]]
