                            ["run", ["s", ["v", "hf"], "reset"]]
                        ], "False": ["pass",
                            ["v", "ball_speed_x", ["mult", -1, ["v", "ball_speed_x"]]],
                            ["inc", "ball_speed_y", ["r", "mult", "paddle_l_dir", "steering"]],
                            ["v", "ball_x", 1]
                        ]
                    }
                ]}],
                ["v", "_paddle_y", "paddle_r_y"],
                ["if", ["r", "gt", "ball_x", ["room_w"]], {"True": ["if", 
                    ["run", ["s", ["v", "hf"], "paddle_collision"]], {
                        "True": ["pass",
                            ["inc", "score_l", 1],
                            ["run", ["s", ["v", "hf"], "reset"]]
                        ], "False": ["pass",
                            ["v", "ball_speed_x", ["mult", -1, ["v", "ball_speed_x"]]],
                            ["inc", "ball_speed_y", ["r", "mult", "paddle_r_dir", "steering"]],
                            ["v", "ball_x", ["sub", ["room_w"], 1]]
                        ]
                    }
                ]}]
            ],
            "paddle_clamp": ["pass",
                ["v", ["v", "_paddle_y"], ["clamp", 
                    ["v", ["v", "_paddle_y"]],
                    ["add", 0, ["v", "paddle_h_half"]],
                    ["sub", ["room_h"], ["v", "paddle_h_half"]]
                ]]
            ]
        }],
        ["run", ["s", ["v", "hf"], "reset"]]
    ], "step": ["pass",
