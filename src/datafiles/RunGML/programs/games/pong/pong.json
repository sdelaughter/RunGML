        ]}],
        ["if", ["control_check", ["v", "controls"], "p1_down"], {"True": ["pass",
            ["inc", "paddle_l_y", ["mult", ["delta"], ["v", "paddle_speed"]]],
            ["run", ["s", ["v", "hf"], "paddle_clamp"]],
            ["v", "paddle_l_dir", 1]
        ]}],
        ["v", "_paddle_y", "paddle_r_y"],
        ["if", 
