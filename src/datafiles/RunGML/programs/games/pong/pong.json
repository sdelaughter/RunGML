                ["inc", "ball_y", ["mult", ["delta"], ["v", "ball_speed_y"]]],
                ["if", ["lt", ["v", "ball_y"], 0], {"True": ["pass",
                    ["v", "ball_speed_y", ["mult", -1, ["v", "ball_speed_y"]]],
                    ["v", "ball_y", 0]
                ]}],
                ["if", ["gt", ["v", "ball_y"], ["room_h"]], {"True": ["pass",
                    ["v", "ball_speed_y", ["mult", -1, ["v", "ball_speed_y"]]],
                    ["v", "ball_y", ["room_h"]]
                ]}],
                ["v", "_paddle_y", "paddle_l_y"],
                ["if", ["r", "lt", "ball_x", 0], {"True": ["if", 
