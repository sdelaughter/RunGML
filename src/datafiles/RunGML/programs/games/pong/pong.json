            ]}
        ],
        ["if",
            ["or",
                ["control_check", ["v", "controls"], "p2_down"],
                ["and", ["v", "singleplayer"], ["r", "gt", "ball_y", "paddle_r_y"]]
            ], {"True": ["pass",
                ["inc", "paddle_r_y", ["mult", ["delta"], ["v", "paddle_speed"]]],
                ["run", ["s", ["v", "hf"], "paddle_clamp"]],
                ["v", "paddle_r_dir", 1]
            ]}
        ],
        ["run", ["s", ["v", "hf"], "move_ball"]]
    ], "draw": [
        ["draw_color", ["c_white"]],
        ["draw_alpha", 1.0],
